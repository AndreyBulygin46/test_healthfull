{
  "name": "prediction-game",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:unit": "jest src/__tests__/unit",
    "test:integration": "node scripts/run-integration-tests.js",
    "test:smoke": "node scripts/run-integration-tests.js src/__tests__/integration/smoke-flow.test.ts --runInBand",
    "test:e2e": "playwright test",
    "e2e:prepare": "node scripts/e2e-prepare.js",
    "test:e2e:smoke": "npm run e2e:prepare && playwright test tests/e2e/smoke.spec.ts",
    "test:e2e:full": "npm run e2e:prepare && playwright test tests/e2e",
    "test:watch": "jest --watch",
    "seed": "node scripts/run-seed.js"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@tanstack/react-query": "^5.99.0",
    "@types/bcryptjs": "^2.4.6",
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "next": "16.2.3",
    "next-auth": "^4.24.13",
    "prisma": "^7.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "playwright": "^1.59.1",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.9",
    "typescript": "^5"
  }
}
