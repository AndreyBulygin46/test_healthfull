generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id             String          @id @default(cuid())
  name           String?
  email          String          @unique
  emailVerified  DateTime?
  password       String?
  image          String?
  role           UserRole        @default(USER)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  accounts       Account[]
  sessions       Session[]
  predictions    Prediction[]
  scores         Score[]
  leaderboardEntries LeaderboardEntry[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Match {
  id            String       @id @default(cuid())
  title         String
  sportType     SportType
  streamUrl     String
  externalId    String?      @unique
  status        MatchStatus  @default(UPCOMING)
  startTime     DateTime
  endTime       DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  events        Event[]
  predictions   Prediction[]
  leaderboardEntries LeaderboardEntry[]
}

model Event {
  id            String    @id @default(cuid())
  matchId       String
  type          String
  timestamp     DateTime
  description   String?
  player        String?
  team          String?
  metadata      String?
  createdAt     DateTime  @default(now())

  match         Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([timestamp])
}

model Prediction {
  id            String          @id @default(cuid())
  userId        String
  matchId       String
  type          PredictionType
  predictedAt   DateTime
  targetEvent   String?
  metadata      String?
  createdAt     DateTime        @default(now())

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  match         Match           @relation(fields: [matchId], references: [id], onDelete: Cascade)
  score         Score?

  @@index([userId])
  @@index([matchId])
  @@index([predictedAt])
}

model Score {
  id            String       @id @default(cuid())
  predictionId  String       @unique
  userId        String
  points        Int
  accuracyMs    Int
  calculatedAt  DateTime     @default(now())

  prediction    Prediction   @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([points])
}

model LeaderboardEntry {
  id            String    @id @default(cuid())
  userId        String
  matchId       String?
  totalPoints   Int       @default(0)
  matchesPlayed Int       @default(0)
  rank          Int?
  period        String    @default("all_time")
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  match         Match?    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId, period])
  @@index([matchId, period])
}

enum UserRole {
  USER
  ADMIN
}

enum SportType {
  CS2
  FOOTBALL
  DOTA2
  VALORANT
}

enum MatchStatus {
  UPCOMING
  LIVE
  FINISHED
  CANCELLED
}

enum PredictionType {
  INSTANT
  INTERVAL
}
